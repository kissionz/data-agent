# Local browser demo keeps deterministic fixture execution.
CHATBI_QUERY_MODE=fixture

# For the Node API PostgreSQL worker, set the mode to postgresql and keep the
# connection string behind this server-side credential reference.
CHATBI_QUERY_CREDENTIAL_REF=env:CHATBI_QUERY_DATABASE_URL
CHATBI_QUERY_DATABASE_URL=postgresql://chatbi_reader:change-me@127.0.0.1:55432/chatbi_warehouse
CHATBI_QUERY_SSL_MODE=disable
CHATBI_QUERY_POOL_MAX=4
CHATBI_QUERY_CONNECT_TIMEOUT_MS=5000
CHATBI_QUERY_IDLE_TIMEOUT_MS=30000
CHATBI_QUERY_STATEMENT_TIMEOUT_MS=15000
CHATBI_QUERY_WORKER_POLL_MS=250
CHATBI_QUERY_LEASE_MS=30000

# Mutable Run/Job/result/event state uses a separate PostgreSQL role and pool.
CHATBI_CONTROL_PLANE_CREDENTIAL_REF=env:CHATBI_CONTROL_PLANE_DATABASE_URL
CHATBI_CONTROL_PLANE_DATABASE_URL=postgresql://chatbi_control_plane:change-me@127.0.0.1:55432/chatbi_control_plane
CHATBI_CONTROL_PLANE_SSL_MODE=disable
CHATBI_CONTROL_PLANE_POOL_MAX=4
CHATBI_CONTROL_PLANE_CONNECT_TIMEOUT_MS=5000
CHATBI_CONTROL_PLANE_IDLE_TIMEOUT_MS=30000
CHATBI_CONTROL_PLANE_CANCELLATION_POLL_MS=250
CHATBI_CONTROL_PLANE_WORKER_DRAIN_MS=30000
CHATBI_CONTROL_PLANE_RECONCILE_INTERVAL_MS=30000
CHATBI_CONTROL_PLANE_RECONCILE_BATCH_SIZE=100

# staging/production PostgreSQL deployments require signed durable outbox
# delivery. Local/test defaults to disabled unless explicitly set to http.
CHATBI_OUTBOX_MODE=disabled
CHATBI_OUTBOX_HTTP_URL=https://events.example.com/chatbi/outbox
CHATBI_OUTBOX_HMAC_SECRET_REF=env:CHATBI_OUTBOX_HMAC_SECRET
CHATBI_OUTBOX_HMAC_SECRET=replace-with-at-least-32-random-bytes
CHATBI_OUTBOX_POLL_MS=250
CHATBI_OUTBOX_LEASE_MS=30000
CHATBI_OUTBOX_HTTP_TIMEOUT_MS=10000
CHATBI_OUTBOX_RETRY_INITIAL_MS=1000
CHATBI_OUTBOX_RETRY_MAX_MS=300000
CHATBI_OUTBOX_MAX_ATTEMPTS=5

# Local/test keeps result blobs inline. staging/production PostgreSQL must set
# mode=s3 and provide every commented S3 setting below. The credential variable
# is resolved only in the Node composition root as a structured
# accessKeyId/secretAccessKey/(optional) sessionToken bundle.
CHATBI_RESULT_STORAGE_MODE=inline
# CHATBI_RESULT_STORAGE_S3_ENDPOINT=https://objects.example.com
# CHATBI_RESULT_STORAGE_S3_REGION=us-east-1
# CHATBI_RESULT_STORAGE_S3_BUCKET=chatbi-results-prod
# CHATBI_RESULT_STORAGE_CREDENTIAL_REF=env:CHATBI_RESULT_STORAGE_CREDENTIALS
# CHATBI_RESULT_STORAGE_CREDENTIALS={"accessKeyId":"replace-me","secretAccessKey":"replace-me"}
CHATBI_RESULT_STORAGE_TIMEOUT_MS=15000
CHATBI_RESULT_STORAGE_MAX_BLOB_BYTES=67108864
